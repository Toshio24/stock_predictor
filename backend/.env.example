# =============================================================================
# Signal — backend environment template
# =============================================================================
# Copy to backend/.env and fill in the keys. The .env file is gitignored —
# NEVER paste real keys into chat or commit them. The backend reads these
# at startup; the frontend never sees them.
# =============================================================================

# --- Required for live news + AI classification ------------------------------
# Finnhub free-tier key — register at https://finnhub.io
FINNHUB_API_KEY=

# Anthropic Claude API key — get from https://console.anthropic.com
# Used by the classifier worker to label news as bullish/bearish/neutral.
ANTHROPIC_API_KEY=

# --- Optional (free) ---------------------------------------------------------
# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
# Powers macro overlay (CPI / unemployment / fed funds / 10y yield).
FRED_API_KEY=

# --- Infrastructure (defaults work inside docker-compose) -------------------
DATABASE_URL=postgresql+psycopg://signal:signal@localhost:5432/signal
REDIS_URL=redis://localhost:6379/0

# Comma-separated symbols. Leave blank to fall back to the seed list.
TRACKED_TICKERS=

# --- Security ----------------------------------------------------------------
# Comma-separated origins allowed to call the API. NEVER use "*" in prod.
CORS_ORIGINS=http://localhost:3000

# Comma-separated hostnames the API will accept Host headers for.
# Prevents host-header injection. Use your real prod domain here.
ALLOWED_HOSTS=localhost,127.0.0.1

# Set to "prod" or "staging" to enable strict mode (HTTPS-only cookies,
# strict CORS, hard rate limits, no debug endpoints).
APP_ENV=dev

# Firebase project id — when set, /api/* routes require a valid Firebase
# ID token (Authorization: Bearer <token>). Leave blank to disable auth
# (dev only).
FIREBASE_PROJECT_ID=

# Optional: comma-separated emails (or UIDs) allowed past auth. Leave blank
# to allow any verified Firebase user. Useful for early private beta.
ALLOWED_USERS=

# Per-IP request budget. Tighten in prod.
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# --- Database creds (used only by docker-compose, not the app) --------------
# For local dev the defaults are fine. For prod, override with a managed
# database URL (DATABASE_URL above) and ignore these.
POSTGRES_USER=signal
POSTGRES_PASSWORD=signal
POSTGRES_DB=signal
