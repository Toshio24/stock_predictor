<div class="glass-card p-10 text-center max-w-2xl mx-auto">
  <div class="w-14 h-14 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-accent to-purple-500 grid place-items-center text-white">
    <%- include('icon', { name: icon || 'chart', size: 24 }) %>
  </div>
  <h2 class="text-[20px] font-bold mb-2" style="color: var(--text-strong);"><%= title %></h2>
  <p class="text-[14px] mb-5" style="color: var(--text-muted);"><%= description %></p>
  <% if (typeof features !== 'undefined' && features.length) { %>
    <ul class="text-left max-w-md mx-auto space-y-2 mb-5">
      <% features.forEach(function(f) { %>
        <li class="flex items-start gap-2 text-[13px]" style="color: var(--text);">
          <span class="text-bull mt-0.5"><%- include('icon', { name: 'check', size: 14 }) %></span>
          <span><%= f %></span>
        </li>
      <% }); %>
    </ul>
  <% } %>
  <div class="flex justify-center gap-2">
    <button class="glass-button">Notify me</button>
    <a href="/" class="glass-button primary">← Back to dashboard</a>
  </div>
</div>
