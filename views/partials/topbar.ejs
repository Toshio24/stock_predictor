<header class="glass-nav sticky top-0 z-30 px-4 lg:px-8 py-3 flex items-center gap-3">
  <button id="mobile-menu" class="lg:hidden p-2 rounded-md hover:bg-white/10" style="color: var(--text);" aria-label="Open menu">
    <%- include('icon', { name: 'menu', size: 18 }) %>
  </button>

  <!-- Search -->
  <div class="relative flex-1 max-w-xl">
    <div class="relative">
      <span class="absolute left-3 top-1/2 -translate-y-1/2" style="color: var(--text-muted);">
        <%- include('icon', { name: 'search', size: 16 }) %>
      </span>
      <input id="global-search" type="search" placeholder="<%= t('Search tickers, pages…') %>  (⌘K)" class="glass-input pl-10 pr-16" autocomplete="off" />
      <span class="hidden sm:flex absolute right-3 top-1/2 -translate-y-1/2 items-center gap-1 text-[10px] font-mono px-1.5 py-0.5 rounded border" style="color: var(--text-muted); border-color: rgba(var(--border-rgb),0.15);">⌘K</span>
    </div>
    <div id="search-results" class="dropdown glass-card" style="left: 0; right: auto; width: 100%;"></div>
  </div>

  <!-- Market status -->
  <div class="hide-mobile glass-button" style="cursor: default;">
    <span class="w-2 h-2 rounded-full <%= marketStatus.open ? 'bg-emerald-500' : 'bg-amber-500' %>"></span>
    <span class="text-[12px] font-medium"><%= marketStatus.label %></span>
    <span class="text-[11px] hidden xl:inline" style="color: var(--text-muted);"><%= marketStatus.next %></span>
  </div>

  <!-- Language toggle -->
  <a href="/lang/<%= lang === 'zh' ? 'en' : 'zh' %>" class="glass-button text-[12px] font-medium" style="text-decoration:none;" aria-label="Switch language" title="<%= lang === 'zh' ? 'Switch to English' : '切换到中文' %>">
    <%= lang === 'zh' ? 'EN' : '中文' %>
  </a>

  <!-- Theme toggle -->
  <button id="theme-toggle" class="glass-button" aria-label="Toggle theme">
    <span class="theme-light"><%- include('icon', { name: 'sun', size: 16 }) %></span>
    <span class="theme-dark hidden"><%- include('icon', { name: 'moon', size: 16 }) %></span>
  </button>

  <!-- Notifications -->
  <div class="relative">
    <button id="notif-trigger" class="glass-button relative" aria-label="Notifications">
      <%- include('icon', { name: 'bell', size: 16 }) %>
      <% var unread = notifications.filter(function(n){ return !n.read; }).length; %>
      <% if (unread) { %>
        <span class="absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold grid place-items-center"><%= unread %></span>
      <% } %>
    </button>
    <div id="notif-dropdown" class="dropdown glass-card">
      <div class="flex items-center justify-between px-3 py-2.5 border-b" style="border-color: rgba(var(--border-rgb),0.06);">
        <div class="font-semibold text-[13px]" style="color: var(--text-strong);"><%= t('Notifications') %></div>
        <button data-action="mark-all" class="text-[11px] font-medium" style="color: var(--accent);"><%= t('Mark all read') %></button>
      </div>
      <div class="max-h-[380px] overflow-y-auto py-1">
        <% notifications.forEach(function(n){ %>
          <div data-notif-id="<%= n.id %>" class="group flex gap-3 px-3 py-2.5 rounded-lg hover:bg-white/5 transition cursor-pointer relative <%= n.read ? 'opacity-60' : '' %>">
            <div class="w-8 h-8 rounded-lg grid place-items-center flex-shrink-0
              <%= n.type === 'signal' ? 'bg-blue-500/20 text-blue-500' :
                  n.type === 'price'  ? 'bg-emerald-500/20 text-emerald-500' :
                  n.type === 'news'   ? 'bg-amber-500/20 text-amber-500' :
                  'bg-slate-500/20 text-slate-400' %>">
              <%- include('icon', { name: n.type === 'price' ? 'arrowUp' : n.type === 'news' ? 'news' : n.type === 'signal' ? 'signals' : 'settings', size: 14 }) %>
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-[13px] font-medium truncate" style="color: var(--text-strong);"><%= n.title %></div>
              <div class="text-[12px] truncate" style="color: var(--text-muted);"><%= n.body %></div>
              <div class="text-[10px] mt-0.5" style="color: var(--text-muted);"><%= n.timeAgo %> <%= t('ago') %></div>
            </div>
            <button data-action="delete" class="opacity-0 group-hover:opacity-100 transition self-start p-1 rounded hover:bg-white/10" aria-label="Delete">
              <%- include('icon', { name: 'trash', size: 12 }) %>
            </button>
          </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- User avatar -->
  <div class="relative">
    <button id="avatar-trigger" class="w-9 h-9 rounded-full bg-gradient-to-br from-accent to-purple-500 grid place-items-center text-white text-xs font-bold">
      <%= user.initials %>
    </button>
    <div id="avatar-dropdown" class="dropdown glass-card" style="min-width: 220px;">
      <div class="px-3 py-2.5 border-b" style="border-color: rgba(var(--border-rgb),0.06);">
        <div class="text-[13px] font-semibold" style="color: var(--text-strong);"><%= user.name %></div>
        <div class="text-[11px]" style="color: var(--text-muted);"><%= user.email %></div>
      </div>
      <div class="py-1">
        <a href="/settings" class="block px-3 py-2 text-[13px] rounded hover:bg-white/5" style="color: var(--text);"><%= t('Settings') %></a>
        <a href="/portfolio" class="block px-3 py-2 text-[13px] rounded hover:bg-white/5" style="color: var(--text);"><%= t('Portfolio') %></a>
        <a href="/alerts" class="block px-3 py-2 text-[13px] rounded hover:bg-white/5" style="color: var(--text);"><%= t('Alerts') %></a>
        <hr class="my-1" style="border-color: rgba(var(--border-rgb),0.06);" />
        <a href="#" data-logout class="block px-3 py-2 text-[13px] rounded hover:bg-white/5" style="color: var(--bear);"><%= t('Log out') %></a>
      </div>
    </div>
  </div>
</header>
