<!doctype html>
<html lang="<%= lang === 'zh' ? 'zh-CN' : 'en' %>" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> · Signal</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <script src="https://cdn.tailwindcss.com" nonce="<%= cspNonce %>"></script>
  <script nonce="<%= cspNonce %>">
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            bull: '#10B981',
            bear: '#EF4444',
            neutral: '#F59E0B',
            accent: '#3B82F6',
          },
        },
      },
    };
    // restore theme before paint to avoid flash
    (function() {
      const saved = localStorage.getItem('signal:theme');
      const dark = saved ? saved === 'dark' : true;
      document.documentElement.classList.toggle('dark', dark);
    })();
  </script>

  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div id="app" class="flex min-h-screen">
    <%- include('../partials/sidebar', { nav: nav, currentPath: currentPath, user: user }) %>
    <div class="main-shell flex-1 flex flex-col min-w-0">
      <%- include('../partials/topbar', { marketStatus: marketStatus, notifications: notifications, user: user }) %>
      <main class="flex-1 px-6 lg:px-10 py-6 lg:py-8 fade-in">
        <%- include('../' + view) %>
      </main>
    </div>
    <div id="sidebar-backdrop" class="sidebar-backdrop"></div>
  </div>

  <%- include('../partials/mobile-nav', { currentPath: currentPath }) %>

  <div id="toast-host"></div>

  <script nonce="<%= cspNonce %>">
    window.firebaseConfig = <%- JSON.stringify(firebaseConfig) %>;
  </script>
  <script type="module" src="/js/firebase-auth.js" nonce="<%= cspNonce %>"></script>
  <script src="/js/sparkline.js" nonce="<%= cspNonce %>"></script>
  <script src="/js/app.js" nonce="<%= cspNonce %>"></script>
</body>
</html>
