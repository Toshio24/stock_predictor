<!doctype html>
<html lang="<%= lang === 'zh' ? 'zh-CN' : 'en' %>" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title><%= title %> · Signal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com" nonce="<%= cspNonce %>"></script>
  <script nonce="<%= cspNonce %>">
    tailwind.config = { darkMode: 'class' };
    (function() {
      const saved = localStorage.getItem('signal:theme');
      const dark = saved ? saved === 'dark' : true;
      document.documentElement.classList.toggle('dark', dark);
    })();
  </script>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="auth-shell">
  <a href="/lang/<%= lang === 'zh' ? 'en' : 'zh' %>" class="glass-button text-[12px] font-medium" style="position:fixed; top:16px; right:16px; text-decoration:none; z-index:50;" aria-label="Switch language">
    <%= lang === 'zh' ? 'EN' : '中文' %>
  </a>
  <main class="w-full max-w-md fade-in">
    <%- include('../' + view) %>
  </main>
  <script nonce="<%= cspNonce %>">
    window.firebaseConfig = <%- JSON.stringify(firebaseConfig) %>;
  </script>
  <script type="module" src="/js/firebase-auth.js" nonce="<%= cspNonce %>"></script>
  <script src="/js/app.js" nonce="<%= cspNonce %>"></script>
</body>
</html>
