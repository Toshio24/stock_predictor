<div class="mb-6">
  <h1 class="text-2xl lg:text-3xl font-bold mb-1" style="color: var(--text-strong);">Settings</h1>
  <p class="text-[14px]" style="color: var(--text-muted);">Preferences, integrations, billing.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
  <aside class="lg:col-span-1">
    <nav class="flex lg:flex-col gap-1">
      <button class="nav-item active">Profile</button>
      <button class="nav-item">Appearance</button>
      <button class="nav-item">Notifications</button>
      <button class="nav-item">Data sources</button>
      <button class="nav-item">Billing</button>
      <button class="nav-item">API keys</button>
    </nav>
  </aside>

  <section class="lg:col-span-3 space-y-6">
    <div class="glass-card p-6">
      <span class="section-title">Profile</span>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);">Full name</label>
          <input class="glass-input" value="Toshi Nagai" />
        </div>
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);">Email</label>
          <input class="glass-input" value="test@gmail.com" />
        </div>
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);">Timezone</label>
          <input class="glass-input" value="America/Los_Angeles" />
        </div>
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);">Base currency</label>
          <input class="glass-input" value="USD" />
        </div>
      </div>
    </div>

    <div class="glass-card p-6">
      <span class="section-title">Appearance</span>
      <div class="flex flex-wrap gap-2 mb-4">
        <button class="glass-tab active">Dark</button>
        <button class="glass-tab">Light</button>
        <button class="glass-tab">System</button>
      </div>
      <div class="text-[12px]" style="color: var(--text-muted);">Tip: use the sun/moon button in the top bar — it persists locally.</div>
    </div>

    <div class="glass-card p-6">
      <span class="section-title">Danger zone</span>
      <p class="text-[13px] mb-3" style="color: var(--text-muted);">Permanently delete your account and revoke all integrations.</p>
      <button class="glass-button" style="border-color: rgba(239, 68, 68, 0.4); color: var(--bear);">Delete account</button>
    </div>
  </section>
</div>
