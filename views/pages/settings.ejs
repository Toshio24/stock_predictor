<div class="mb-6">
  <h1 class="text-2xl lg:text-3xl font-bold mb-1" style="color: var(--text-strong);"><%= t('Settings') %></h1>
  <p class="text-[14px]" style="color: var(--text-muted);"><%= t('Preferences, integrations, billing.') %></p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
  <aside class="lg:col-span-1">
    <nav class="flex lg:flex-col gap-1">
      <button class="nav-item active"><%= t('Profile') %></button>
      <button class="nav-item"><%= t('Appearance') %></button>
      <button class="nav-item"><%= t('Notifications') %></button>
      <button class="nav-item"><%= t('Data sources') %></button>
      <button class="nav-item"><%= t('Billing') %></button>
      <button class="nav-item"><%= t('API keys') %></button>
    </nav>
  </aside>

  <section class="lg:col-span-3 space-y-6">
    <div class="glass-card p-6">
      <span class="section-title"><%= t('Profile') %></span>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);"><%= t('Full name') %></label>
          <input class="glass-input" value="Toshi Nagai" />
        </div>
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);"><%= t('Email') %></label>
          <input class="glass-input" value="test@gmail.com" />
        </div>
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);"><%= t('Timezone') %></label>
          <input class="glass-input" value="America/Los_Angeles" />
        </div>
        <div>
          <label class="text-[12px] font-medium mb-1.5 block" style="color: var(--text-muted);"><%= t('Base currency') %></label>
          <input class="glass-input" value="USD" />
        </div>
      </div>
    </div>

    <div class="glass-card p-6">
      <span class="section-title"><%= t('Appearance') %></span>
      <div class="flex flex-wrap gap-2 mb-4">
        <button class="glass-tab active"><%= t('Dark') %></button>
        <button class="glass-tab"><%= t('Light') %></button>
        <button class="glass-tab"><%= t('System') %></button>
      </div>
      <div class="text-[12px]" style="color: var(--text-muted);"><%= t('Tip: use the sun/moon button in the top bar — it persists locally.') %></div>
    </div>

    <div class="glass-card p-6">
      <span class="section-title"><%= t('Danger zone') %></span>
      <p class="text-[13px] mb-3" style="color: var(--text-muted);"><%= t('Permanently delete your account and revoke all integrations.') %></p>
      <button class="glass-button" style="border-color: rgba(239, 68, 68, 0.4); color: var(--bear);"><%= t('Delete account') %></button>
    </div>
  </section>
</div>
