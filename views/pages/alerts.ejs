<div class="flex items-center justify-between mb-6 flex-wrap gap-3">
  <div>
    <h1 class="text-2xl lg:text-3xl font-bold mb-1" style="color: var(--text-strong);">Alerts</h1>
    <p class="text-[14px]" style="color: var(--text-muted);">Price, signal, and news triggers — push, email, or webhook.</p>
  </div>
  <button class="glass-button primary">+ New alert</button>
</div>

<div class="glass-table">
  <table class="w-full">
    <thead>
      <tr>
        <th>Trigger</th>
        <th>Symbol</th>
        <th>Channel</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% [
        ['Score crosses 90', 'NVDA', 'Push + Email', 'active'],
        ['Price below $230', 'AAPL', 'Push', 'active'],
        ['Bearish signal opens', 'TSLA', 'Email', 'active'],
        ['News mentions "buyback"', 'META', 'Webhook', 'paused'],
        ['Volume > 2× avg', 'COIN', 'Push', 'active'],
      ].forEach(function(r) { %>
        <tr>
          <td style="color: var(--text-strong);"><%= r[0] %></td>
          <td><span class="ticker-badge"><%= r[1] %></span></td>
          <td class="text-[12px]" style="color: var(--text-muted);"><%= r[2] %></td>
          <td>
            <span class="sentiment-badge <%= r[3] === 'active' ? 'bullish' : 'neutral' %>"><%= r[3] %></span>
          </td>
          <td class="text-right">
            <button class="glass-tab">Edit</button>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
