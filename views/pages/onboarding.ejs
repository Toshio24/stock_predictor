<div class="auth-card">
  <div class="flex items-center gap-3 mb-6">
    <div class="brand-square"><%- include('../partials/icon', { name: 'chart', size: 18 }) %></div>
    <div>
      <div class="text-[16px] font-bold">Signal</div>
      <div class="text-[10px] uppercase tracking-widest opacity-60"><%= t('AI Trading') %></div>
    </div>
  </div>

  <h1 class="text-[22px] font-bold mb-1"><%= t('Welcome to Signal') %></h1>
  <p class="text-[13px] opacity-70 mb-6"><%= t('Three quick questions to tune your dashboard.') %></p>

  <form action="/" method="get" class="space-y-5">
    <div>
      <div class="text-[12px] font-medium mb-2"><%= t('What do you trade?') %></div>
      <div class="flex flex-wrap gap-2">
        <button type="button" class="glass-tab active"><%= t('Equities') %></button>
        <button type="button" class="glass-tab"><%= t('Crypto') %></button>
        <button type="button" class="glass-tab"><%= t('Futures') %></button>
        <button type="button" class="glass-tab"><%= t('Options') %></button>
      </div>
    </div>
    <div>
      <div class="text-[12px] font-medium mb-2"><%= t('Time horizon') %></div>
      <div class="flex flex-wrap gap-2">
        <button type="button" class="glass-tab"><%= t('Intraday') %></button>
        <button type="button" class="glass-tab active"><%= t('Swing') %></button>
        <button type="button" class="glass-tab"><%= t('Position') %></button>
      </div>
    </div>
    <div>
      <div class="text-[12px] font-medium mb-2"><%= t('Risk profile') %></div>
      <div class="flex flex-wrap gap-2">
        <button type="button" class="glass-tab"><%= t('Conservative') %></button>
        <button type="button" class="glass-tab active"><%= t('Balanced') %></button>
        <button type="button" class="glass-tab"><%= t('Aggressive') %></button>
      </div>
    </div>
    <button type="submit" class="glass-button primary w-full justify-center" style="padding: 12px;"><%= t('Take me to my dashboard') %></button>
  </form>
</div>
