<div class="auth-card">
  <div class="flex items-center gap-3 mb-6">
    <div class="brand-square"><%- include('../partials/icon', { name: 'chart', size: 18 }) %></div>
    <div>
      <div class="text-[16px] font-bold">Signal</div>
      <div class="text-[10px] uppercase tracking-widest opacity-60">AI Trading</div>
    </div>
  </div>

  <h1 class="text-[22px] font-bold mb-1">Reset your password</h1>
  <p class="text-[13px] opacity-70 mb-6">We'll email you a link to reset it.</p>

  <form data-auth="forgot" class="space-y-4">
    <div>
      <label class="text-[12px] font-medium mb-1.5 block">Email</label>
      <input name="email" type="email" required class="glass-input" placeholder="you@company.com" />
    </div>
    <button type="submit" class="glass-button primary w-full justify-center" style="padding: 12px;">Send reset link</button>
  </form>

  <p class="text-[12px] text-center mt-6 opacity-70">
    <a href="/login" style="color: var(--accent);" class="font-medium">← Back to log in</a>
  </p>
</div>
