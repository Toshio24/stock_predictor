<%
  // Convenience picks — surface the 5d horizon as the "primary" one in the
  // hero stats since it's the swing-trading sweet spot the composite is
  // tuned for. 1d and 21d are still shown alongside.
  const horizons = (perf && perf.horizons) || [];
  const byH = Object.fromEntries(horizons.map((h) => [h.horizon, h]));
  const primary = byH['5d'] || horizons[0] || null;
  const totalResolved = horizons.reduce((s, h) => s + (h.resolved || 0), 0);
  const totalPending = horizons.reduce((s, h) => s + (h.pending || 0), 0);
  const hasAnyModel = horizons.some((h) => h.model);
  const spend = (perf && perf.spend) || { today_usd: 0, month_usd: 0, total_usd: 0, total_n: 0, today_n: 0, month_n: 0, avg_usd_per_call: null };
  // Soft alert when month-to-date exceeds $15 — buys a heads-up before
  // the $20 wallet runs dry. Tune to your own threshold via the constant
  // below or move to a setting later.
  const BUDGET_WARN_USD = 15;
  const overBudget = spend.month_usd >= BUDGET_WARN_USD;
  const fmtPct = (v) => (v === null || v === undefined) ? '—' : (v.toFixed ? v.toFixed(1) : v) + '%';
  const fmtProb = (v) => (v === null || v === undefined) ? '—' : (Number(v) * 100).toFixed(1) + '%';
  const fmtNum = (v, d = 2) => (v === null || v === undefined) ? '—' : Number(v).toFixed(d);
  const fmtAgo = (iso) => {
    if (!iso) return '—';
    const ms = Date.now() - new Date(iso).getTime();
    if (ms < 60000) return 'just now';
    if (ms < 3600000) return Math.floor(ms / 60000) + 'm ago';
    if (ms < 86400000) return Math.floor(ms / 3600000) + 'h ago';
    return Math.floor(ms / 86400000) + 'd ago';
  };
%>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl lg:text-3xl font-bold mb-1" style="color: var(--text-strong);"><%= t('ML Data') %></h1>
    <p class="text-[14px]" style="color: var(--text-muted);">
      <%= t('Calibrated probability layer on top of the composite signal — track how well predictions match reality.') %>
    </p>
  </div>
  <div class="text-right text-[12px]" style="color: var(--text-muted);">
    <%= totalResolved %> <%= t('resolved') %> · <%= totalPending %> <%= t('pending') %><br />
    <%= t('Refreshed') %> <%= fmtAgo(perf && perf.generated_at) %>
  </div>
</div>

<!-- ============================== CLAUDE API SPEND ============================== -->
<section class="glass-card p-5 mb-6 spend-card <%= overBudget ? 'is-over-budget' : '' %>">
  <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
    <div>
      <h3 class="text-[15px] font-bold" style="color: var(--text-strong);"><%= t('Claude API spend') %></h3>
      <p class="text-[12px]" style="color: var(--text-muted);">
        <%= t('Live from') %> <code>llm_analyses.cost_usd</code> <%= t('— recorded at each classification call. Anthropic Console:') %>
        <a href="https://console.anthropic.com/settings/usage" target="_blank" rel="noopener noreferrer" class="spend-link hover:underline">console.anthropic.com/settings/usage ↗</a>
      </p>
    </div>
    <% if (overBudget) { %>
      <span class="text-[11px] px-2 py-1 rounded-full spend-badge">
        <%= t('Over') %> $<%= BUDGET_WARN_USD %> <%= t('this month') %>
      </span>
    <% } %>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div>
      <div class="text-[11px] uppercase tracking-widest mb-1 spend-label"><%= t('Today') %></div>
      <div class="text-2xl font-bold tabular-nums spend-value">$<%= fmtNum(spend.today_usd, 2) %></div>
      <div class="text-[11px] mt-0.5 spend-label"><%= spend.today_n %> <%= t('calls') %></div>
    </div>
    <div>
      <div class="text-[11px] uppercase tracking-widest mb-1 spend-label"><%= t('This month') %></div>
      <div class="text-2xl font-bold tabular-nums spend-value spend-month">
        $<%= fmtNum(spend.month_usd, 2) %>
      </div>
      <div class="text-[11px] mt-0.5 spend-label"><%= spend.month_n %> <%= t('calls') %></div>
    </div>
    <div>
      <div class="text-[11px] uppercase tracking-widest mb-1 spend-label"><%= t('All time') %></div>
      <div class="text-2xl font-bold tabular-nums spend-value">$<%= fmtNum(spend.total_usd, 2) %></div>
      <div class="text-[11px] mt-0.5 spend-label"><%= spend.total_n %> <%= t('calls') %></div>
    </div>
    <div>
      <div class="text-[11px] uppercase tracking-widest mb-1 spend-label"><%= t('Avg / call') %></div>
      <div class="text-2xl font-bold tabular-nums spend-value">
        <%= spend.avg_usd_per_call === null ? '—' : '$' + spend.avg_usd_per_call.toFixed(4) %>
      </div>
      <div class="text-[11px] mt-0.5 spend-label"><%= t('Haiku 4.5 + caching') %></div>
    </div>
  </div>
</section>

<% if (!hasAnyModel) { %>
  <!-- ============================== COLD START ============================== -->
  <section class="glass-card p-6 mb-6">
    <div class="flex items-start gap-4">
      <div class="brand-square" style="background: linear-gradient(135deg, #6366F1, #8B5CF6);">
        <%- include('../partials/icon', { name: 'brain', size: 22 }) %>
      </div>
      <div class="flex-1">
        <h2 class="text-lg font-bold mb-1" style="color: var(--text-strong);"><%= t('Model is warming up') %></h2>
        <p class="text-[14px]" style="color: var(--text-muted); max-width: 60ch;">
          <%= t('No active model yet. The ML layer learns from') %> <code>signal_outcomes</code> <%= t('rows — each composite signal gets paired with its realised 1d/5d/21d forward return once enough trading days pass. Once you have ~50 resolved outcomes per horizon, run the trainer to fit the first model.') %>
        </p>
        <pre class="mt-3 p-3 rounded-lg text-[12px] font-mono overflow-x-auto" style="background: rgba(0,0,0,0.35); color: var(--text-muted);">docker compose run --rm api python -m app.ml.train</pre>
        <p class="text-[13px] mt-3" style="color: var(--text-muted);">
          <%= t('Currently tracking') %> <strong style="color: var(--text-strong);"><%= totalPending %></strong> <%= t('pending signal(s). Once they resolve, this page will show calibration, hit rate, and per-prediction outcomes.') %>
        </p>
      </div>
    </div>
  </section>
<% } else { %>

  <!-- ============================== HERO STATS (5d) ============================== -->
  <section class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="glass-card p-5">
      <div class="text-[11px] uppercase tracking-widest mb-1" style="color: var(--text-muted);"><%= t('Hit rate · 5d') %></div>
      <div class="text-3xl font-bold tabular-nums" style="color: var(--text-strong);">
        <%= fmtPct(primary ? primary.hit_rate_pct : null) %>
      </div>
      <div class="text-[12px] mt-1" style="color: var(--text-muted);">
        <%= t('on') %> <%= primary ? primary.resolved : 0 %> <%= t('resolved · baseline 50%') %>
      </div>
    </div>
    <div class="glass-card p-5">
      <div class="text-[11px] uppercase tracking-widest mb-1" style="color: var(--text-muted);"><%= t('High-confidence hit · 5d') %></div>
      <div class="text-3xl font-bold tabular-nums" style="color: var(--text-strong);">
        <%= fmtPct(primary ? primary.high_conf_hit_rate_pct : null) %>
      </div>
      <div class="text-[12px] mt-1" style="color: var(--text-muted);">
        <%= t('when model said prob ≥ 60%') %>
      </div>
    </div>
    <div class="glass-card p-5">
      <div class="text-[11px] uppercase tracking-widest mb-1" style="color: var(--text-muted);"><%= t('Mean realised · 5d') %></div>
      <div class="text-3xl font-bold tabular-nums"
           style="color: <%= (primary && primary.mean_realized_return_pct !== null && primary.mean_realized_return_pct > 0) ? 'var(--bull)' : 'var(--text-strong)' %>;">
        <%= fmtPct(primary ? primary.mean_realized_return_pct : null) %>
      </div>
      <div class="text-[12px] mt-1" style="color: var(--text-muted);">
        <%= t('avg return on signals, 5 trading days out') %>
      </div>
    </div>
    <div class="glass-card p-5">
      <div class="text-[11px] uppercase tracking-widest mb-1" style="color: var(--text-muted);"><%= t('Holdout accuracy') %></div>
      <div class="text-3xl font-bold tabular-nums" style="color: var(--text-strong);">
        <%= primary && primary.model ? (primary.model.holdout_accuracy_pct + '%') : '—' %>
      </div>
      <div class="text-[12px] mt-1" style="color: var(--text-muted);">
        <%= t('at training time') %> · <%= primary && primary.model ? primary.model.n_test_samples + ' ' + t('test rows') : '—' %>
      </div>
    </div>
  </section>

  <!-- ============================== PER-HORIZON BREAKDOWN ============================== -->
  <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
    <% horizons.forEach(function(h) { %>
      <div class="glass-card p-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-[15px] font-bold" style="color: var(--text-strong);"><%= t('Horizon') %> · <%= h.horizon %></h3>
          <span class="text-[11px] px-2 py-0.5 rounded-full"
                style="background: <%= h.model ? 'rgba(16,185,129,0.15)' : 'rgba(245,158,11,0.15)' %>; color: <%= h.model ? 'var(--bull)' : 'var(--neutral)' %>;">
            <%= h.model ? t('active') : t('no model') %>
          </span>
        </div>
        <dl class="space-y-1.5 text-[13px]">
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('Resolved') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= h.resolved %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('Pending') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= h.pending %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('Hit rate') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= fmtPct(h.hit_rate_pct) %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('High-conf hit') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= fmtPct(h.high_conf_hit_rate_pct) %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('Mean pred. prob') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= h.mean_predicted_prob !== null ? (h.mean_predicted_prob * 100).toFixed(1) + '%' : '—' %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('Brier score') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= h.model ? fmtNum(h.model.brier_score, 3) : '—' %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('ROC-AUC') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= h.model && h.model.roc_auc !== null ? fmtNum(h.model.roc_auc, 3) : '—' %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('Trained') %></dt><dd style="color: var(--text-strong);"><%= h.model ? fmtAgo(h.model.trained_at) : '—' %></dd></div>
          <div class="flex justify-between"><dt style="color: var(--text-muted);"><%= t('Train samples') %></dt><dd class="tabular-nums" style="color: var(--text-strong);"><%= h.model ? h.model.n_train_samples : '—' %></dd></div>
        </dl>
      </div>
    <% }); %>
  </section>

  <!-- ============================== CALIBRATION TABLE ============================== -->
  <% if (primary && primary.calibration && primary.calibration.length) { %>
    <section class="glass-card p-5 mb-6">
      <div class="mb-3">
        <h3 class="text-[15px] font-bold" style="color: var(--text-strong);"><%= t('Calibration · 5d') %></h3>
        <p class="text-[12px]" style="color: var(--text-muted);">
          <%= t('For each probability bucket: what did the model predict, vs. what actually happened. Perfect calibration means the two columns match. Gaps mean the model is over- or under-confident.') %>
        </p>
      </div>
      <table class="w-full text-[13px]">
        <thead>
          <tr style="color: var(--text-muted); border-bottom: 1px solid rgba(255,255,255,0.08);">
            <th class="text-left py-2 font-medium"><%= t('Bucket') %></th>
            <th class="text-right py-2 font-medium"><%= t('N') %></th>
            <th class="text-right py-2 font-medium"><%= t('Predicted prob') %></th>
            <th class="text-right py-2 font-medium"><%= t('Actual hit rate') %></th>
            <th class="text-right py-2 font-medium"><%= t('Gap') %></th>
          </tr>
        </thead>
        <tbody>
          <% primary.calibration.forEach(function(b) { %>
            <% const gap = (b.actual_hit_rate - b.predicted_prob); %>
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
              <td class="py-2 font-mono"><%= b.bucket %></td>
              <td class="text-right py-2 tabular-nums" style="color: var(--text-strong);"><%= b.n %></td>
              <td class="text-right py-2 tabular-nums" style="color: var(--text-muted);"><%= (b.predicted_prob * 100).toFixed(1) %>%</td>
              <td class="text-right py-2 tabular-nums" style="color: var(--text-strong);"><%= (b.actual_hit_rate * 100).toFixed(1) %>%</td>
              <td class="text-right py-2 tabular-nums" style="color: <%= Math.abs(gap) < 0.05 ? 'var(--bull)' : (Math.abs(gap) < 0.15 ? 'var(--neutral)' : 'var(--bear)') %>;">
                <%= (gap >= 0 ? '+' : '') + (gap * 100).toFixed(1) %>%
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </section>
  <% } %>

  <!-- ============================== FEATURE IMPORTANCES ============================== -->
  <% if (primary && primary.model && primary.model.feature_importances) { %>
    <% const fi = primary.model.feature_importances;
       const fiEntries = Object.entries(fi).sort((a, b) => b[1] - a[1]);
       const fiMax = Math.max.apply(null, fiEntries.map((e) => e[1] || 0)) || 1; %>
    <section class="glass-card p-5 mb-6">
      <h3 class="text-[15px] font-bold mb-1" style="color: var(--text-strong);"><%= t('Feature importances · 5d') %></h3>
      <p class="text-[12px] mb-3" style="color: var(--text-muted);">
        <%= t('Which inputs the model leans on. A flat distribution means everything contributes; a spike means one signal is doing most of the work.') %>
      </p>
      <div class="space-y-2">
        <% fiEntries.forEach(function([name, w]) { %>
          <div class="flex items-center gap-3">
            <div class="text-[12px] font-mono w-40" style="color: var(--text-muted);"><%= name %></div>
            <div class="flex-1 h-2 rounded-full" style="background: rgba(255,255,255,0.05);">
              <div class="h-2 rounded-full" style="width: <%= (w / fiMax) * 100 %>%; background: linear-gradient(90deg, #3B82F6, #8B5CF6);"></div>
            </div>
            <div class="text-[12px] tabular-nums w-16 text-right" style="color: var(--text-strong);"><%= (w * 100).toFixed(1) %>%</div>
          </div>
        <% }); %>
      </div>
    </section>
  <% } %>

<% } %>

<!-- ============================== RECENT PREDICTIONS ============================== -->
<section class="glass-card p-5">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-[15px] font-bold" style="color: var(--text-strong);"><%= t('Recent predictions') %></h3>
    <span class="text-[12px]" style="color: var(--text-muted);"><%= t('Last 25 · 5d horizon') %></span>
  </div>
  <% if (!perf.recent || perf.recent.length === 0) { %>
    <p class="text-[14px] py-6 text-center" style="color: var(--text-muted);">
      <%= t('No predictions yet. They start flowing once the composite worker has produced its first batch.') %>
    </p>
  <% } else { %>
    <table class="w-full text-[13px]">
      <thead>
        <tr style="color: var(--text-muted); border-bottom: 1px solid rgba(255,255,255,0.08);">
          <th class="text-left py-2 font-medium"><%= t('When') %></th>
          <th class="text-left py-2 font-medium"><%= t('Ticker') %></th>
          <th class="text-left py-2 font-medium"><%= t('Composite') %></th>
          <th class="text-right py-2 font-medium"><%= t('ML prob ↑ (5d)') %></th>
          <th class="text-right py-2 font-medium"><%= t('Realised 5d') %></th>
          <th class="text-right py-2 font-medium"><%= t('Hit?') %></th>
        </tr>
      </thead>
      <tbody>
        <% perf.recent.forEach(function(r) { %>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
            <td class="py-2" style="color: var(--text-muted);"><%= fmtAgo(r.predicted_at) %></td>
            <td class="py-2">
              <a href="/ticker/<%= r.ticker %>" class="font-mono font-bold hover:underline" style="color: var(--text-strong);">
                <%= r.ticker %>
              </a>
            </td>
            <td class="py-2">
              <span class="text-[11px] px-2 py-0.5 rounded-full uppercase tracking-wider"
                    style="background: <%= r.composite_label === 'bullish' ? 'rgba(16,185,129,0.15)' : (r.composite_label === 'bearish' ? 'rgba(239,68,68,0.15)' : 'rgba(245,158,11,0.15)') %>;
                           color: <%= r.composite_label === 'bullish' ? 'var(--bull)' : (r.composite_label === 'bearish' ? 'var(--bear)' : 'var(--neutral)') %>;">
                <%= r.composite_label %>
              </span>
              <span class="text-[12px] tabular-nums ml-2" style="color: var(--text-muted);"><%= r.composite_score %></span>
            </td>
            <td class="text-right py-2 tabular-nums" style="color: var(--text-strong);"><%= fmtProb(r.prob_up_5d) %></td>
            <td class="text-right py-2 tabular-nums"
                style="color: <%= r.realized_5d_pct === null ? 'var(--text-muted)' : (r.realized_5d_pct > 0 ? 'var(--bull)' : 'var(--bear)') %>;">
              <%= r.realized_5d_pct === null ? t('pending') : ((r.realized_5d_pct > 0 ? '+' : '') + r.realized_5d_pct.toFixed(2) + '%') %>
            </td>
            <td class="text-right py-2">
              <% if (r.hit_5d === null) { %>
                <span style="color: var(--text-muted);">—</span>
              <% } else if (r.hit_5d) { %>
                <span style="color: var(--bull);">✓</span>
              <% } else { %>
                <span style="color: var(--bear);">✗</span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>
